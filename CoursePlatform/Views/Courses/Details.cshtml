@model CoursePlatform.ViewModels.Courses.CourseDetailsViewModel

@{
    ViewData["Title"] = "Course Details";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-controller="Courses" asp-action="Index" class="btn btn-outline-secondary">
            Back to Courses
        </a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h1 class="card-title mb-3">@Model.Title</h1>

            <p><strong>Category:</strong> @Model.CategoryName</p>
            <p><strong>Instructor:</strong> @Model.InstructorName</p>
            <p><strong>Instructor Email:</strong> @Model.InstructorEmail</p>
            <p><strong>Level:</strong> @Model.Level</p>
            <p><strong>Duration:</strong> @Model.DurationHours hours</p>
            <p><strong>Price:</strong> $@Model.Price</p>
            <p><strong>Created At:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd")</p>

            <hr />

            <h4>Description</h4>
            <p>@Model.Description</p>

            <hr />

            <h4>Instructor Bio</h4>
            <p>@Model.InstructorBio</p>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h3 class="mb-3">Comments</h3>

            @if (!Model.Comments.Any())
            {
                <div class="alert alert-light border">
                    No comments yet.
                </div>
            }
            else
            {
                @foreach (var comment in Model.Comments)
                {
                    <div class="border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong>@comment.Username</strong>
                            <span class="text-muted">@comment.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                        </div>
                        <p class="mb-0">@comment.Content</p>
                    </div>
                }
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h3 class="mb-3">Leave a Comment</h3>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Comments" asp-action="Create" method="post">
                    <input asp-for="NewComment.CourseId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="NewComment.Content" class="form-label"></label>
                        <textarea asp-for="NewComment.Content" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="NewComment.Content" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Add Comment</button>
                </form>
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    Only authorized users can leave comments.
                    <a asp-controller="Account" asp-action="Login">Login</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}