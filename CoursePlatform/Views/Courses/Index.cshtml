@model List<CoursePlatform.ViewModels.Courses.CourseListItemViewModel>

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-4">
    <h1 class="mb-4">Courses</h1>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No courses found.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var course in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@course.Title</h5>
                            <p class="card-text text-muted mb-2">
                                <strong>Category:</strong> @course.CategoryName
                            </p>
                            <p class="card-text text-muted mb-2">
                                <strong>Instructor:</strong> @course.InstructorName
                            </p>
                            <p class="card-text text-muted mb-2">
                                <strong>Level:</strong> @course.Level
                            </p>
                            <p class="card-text text-muted mb-2">
                                <strong>Duration:</strong> @course.DurationHours h
                            </p>
                            <p class="card-text text-muted mb-3">
                                <strong>Price:</strong> $@course.Price
                            </p>
                            <p class="card-text flex-grow-1">@course.ShortDescription</p>

                            <a asp-controller="Courses"
                               asp-action="Details"
                               asp-route-id="@course.Id"
                               class="btn btn-primary mt-auto">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>