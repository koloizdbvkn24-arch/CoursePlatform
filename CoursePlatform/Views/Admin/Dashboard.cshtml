@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h1 class="mb-4">Admin Dashboard</h1>

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5>Courses</h5>
                    <p>Manage all courses.</p>
                    <a asp-action="Courses" class="btn btn-primary">Open</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5>Categories</h5>
                    <p>Manage all categories.</p>
                    <a asp-action="Categories" class="btn btn-primary">Open</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5>Instructors</h5>
                    <p>Manage all instructors.</p>
                    <a asp-action="Instructors" class="btn btn-primary">Open</a>
                </div>
            </div>
        </div>
    </div>
</div>