@model List<CoursePlatform.ViewModels.Courses.CourseListItemViewModel>

@{
    ViewData["Title"] = "Manage Courses";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage Courses</h1>
        <a asp-action="CreateCourse" class="btn btn-success">Create Course</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No courses found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Instructor</th>
                        <th>Level</th>
                        <th>Duration</th>
                        <th>Price</th>
                        <th style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td>@course.Title</td>
                            <td>@course.CategoryName</td>
                            <td>@course.InstructorName</td>
                            <td>@course.Level</td>
                            <td>@course.DurationHours h</td>
                            <td>$@course.Price</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="EditCourse" asp-route-id="@course.Id" class="btn btn-warning btn-sm">Edit</a>

                                    <form asp-action="DeleteCourse" method="post">
                                        <input type="hidden" name="id" value="@course.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>