@model List<CoursePlatform.ViewModels.Instructors.InstructorViewModel>

@{
    ViewData["Title"] = "Manage Instructors";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage Instructors</h1>
        <a asp-action="CreateInstructor" class="btn btn-success">Create Instructor</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No instructors found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Bio</th>
                        <th style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var instructor in Model)
                    {
                        <tr>
                            <td>@instructor.FullName</td>
                            <td>@instructor.Email</td>
                            <td>@instructor.Bio</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="EditInstructor" asp-route-id="@instructor.Id" class="btn btn-warning btn-sm">Edit</a>

                                    <form asp-action="DeleteInstructor" method="post">
                                        <input type="hidden" name="id" value="@instructor.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>